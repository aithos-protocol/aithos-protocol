node_modules/
dist/
*.log
.DS_Store

# local keystore; never commit
.aithos/

# scratch
/tmp/

# user-generated ethos bundles are local; the ceremonial birth bundle is checked in.
*.ethos
!birth/aithos-birth.ethos
!cli/birth/aithos-birth.ethos
!stubs/aithos-py/birth/aithos-birth.ethos
!stubs/aithos-rs/birth/aithos-birth.ethos
!stubs/aithos-go/birth/aithos-birth.ethos
packages/cli/src/commands/*.removed
packages/*/dist/commands/*.removed

# local-only scratch files from cutover tooling
.gitignore_v2_cutover

# npm pack outputs (published via npm publish, never committed)
*.tgz

# incremental TypeScript build cache (local artifact, regenerated on build)
*.tsbuildinfo

# FUSE filesystem ghost files (created by sandboxed mounts when files are deleted while open)
.fuse_hidden*
**/.fuse_hidden*

# Office app lock files (LibreOffice / OpenOffice / MS Office)
.~lock.*#
~$*

# Local-only operational / strategic / outreach material — never commit to the public repo
docs/internal/
MIGRATION-APACHE-2.0.md
marketing/
aithos_competitive_map.md
aithos_outreach_devs.xlsx
aithos_outreach_*.xlsx
cdk.out/
