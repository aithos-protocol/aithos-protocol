{
  "name": "@aithos/agent-tools",
  "version": "0.1.0",
  "description": "Aithos agent tools — the canonical, shared catalogue of tool names, normative descriptions, JSON Schemas, scope rules, and legacy aliases consumed by every Aithos tool host (@aithos/mcp server, aithos-sdk, platform compute proxy).",
  "license": "Apache-2.0",
  "author": "Mathieu Colla <mathieu.colla.pro@gmail.com>",
  "homepage": "https://github.com/aithos-protocol/aithos-protocol#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aithos-protocol/aithos-protocol.git",
    "directory": "packages/agent-tools"
  },
  "bugs": {
    "url": "https://github.com/aithos-protocol/aithos-protocol/issues"
  },
  "keywords": [
    "aithos",
    "mcp",
    "ai-agent",
    "tools",
    "catalogue",
    "protocol"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run check-types"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
