{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": [
    "bin/**/*.ts",
    "cdk/**/*.ts",
    "lambda/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": ["dist", "cdk.out", "node_modules", "test", "test-e2e"]
}
