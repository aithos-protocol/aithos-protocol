{
  "name": "@aithos/mcp",
  "version": "0.14.0",
  "description": "Aithos MCP server — exposes an Aithos identity's ethos and mandates to MCP-speaking agents over stdio or HTTP.",
  "license": "Apache-2.0",
  "author": "Mathieu Colla <mathieu.colla.pro@gmail.com>",
  "homepage": "https://github.com/aithos-protocol/aithos-protocol#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aithos-protocol/aithos-protocol.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/aithos-protocol/aithos-protocol/issues"
  },
  "keywords": [
    "aithos",
    "did",
    "identity",
    "ethos",
    "mandate",
    "mcp",
    "ai-agent",
    "protocol"
  ],
  "type": "module",
  "bin": {
    "aithos-mcp": "dist/bin.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./gateway": {
      "types": "./dist/gateway.d.ts",
      "default": "./dist/gateway.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./package.json": "./package.json",
    "./pack": {
      "types": "./dist/pack.d.ts",
      "default": "./dist/pack.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin.js",
    "test": "npm run build && node --test test/*.test.mjs",
    "check-types": "tsc --noEmit",
    "start:stdio": "node dist/bin.js --transport stdio",
    "start:http": "node dist/bin.js --transport http --port 8787",
    "clean": "rm -rf dist",
    "check:browser": "esbuild scripts/iso-entry.mjs --bundle --platform=browser --format=esm --outfile=/dev/null --log-level=error",
    "prepublishOnly": "npm run clean && npm run build && npm run check-types"
  },
  "dependencies": {
    "@aithos/protocol-core": ">=0.10.3 <0.12.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "zod": "^3.23.0",
    "@aithos/agent-tools": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.5.0",
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=20"
  }
}
