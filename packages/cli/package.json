{
  "name": "aithos",
  "version": "0.8.1",
  "description": "Reference CLI for the Aithos protocol: create an Aithos identity, grant and revoke mandates, sign actions, author and publish ethos bundles.",
  "license": "Apache-2.0",
  "author": "Mathieu Colla <mathieu.colla.pro@gmail.com>",
  "homepage": "https://github.com/aithos-protocol/aithos-protocol#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aithos-protocol/aithos-protocol.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/aithos-protocol/aithos-protocol/issues"
  },
  "keywords": [
    "aithos",
    "did",
    "identity",
    "ethos",
    "mandate",
    "ed25519",
    "self-sovereign",
    "ai-agent",
    "protocol",
    "cli"
  ],
  "type": "module",
  "bin": {
    "aithos": "./dist/index.js"
  },
  "files": [
    "dist",
    "birth",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@aithos/protocol-core": "^0.8.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "adm-zip": "^0.5.17",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.11.0",
    "tsx": "^4.11.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
